APP_NAME="Projeto Maquina API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081
APP_HTTP_PORT=8081
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=projeto_maquina
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:8080

JWT_SECRET=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Efi Pay - API Cobranças (Boleto)
EFI_BOLETO_CLIENT_ID=
EFI_BOLETO_CLIENT_SECRET=
EFI_BOLETO_SANDBOX=true
